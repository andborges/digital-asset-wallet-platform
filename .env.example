# Postgres connection string (pgx format). In the local compose stack this is set
# automatically for the api service — this file documents it for running walletd
# outside compose (e.g. go run ./cmd/walletd api).
DATABASE_URL=postgres://walletd:walletd@localhost:5432/walletd?sslmode=disable

# Comma-separated list of valid bearer tokens for v1's single internal consumer.
# Static and operator-provisioned — there is no token-issuance API (see Story 1.1 Dev Notes).
API_BEARER_TOKENS=dev-token

# Address the api role listens on.
API_LISTEN_ADDR=:8080

# Secret used to sign (HMAC-SHA256) transaction-history page cursors, so a tampered or
# cross-customer cursor is rejected rather than silently honored. Required. Use a long,
# random, operator-provisioned value; keep it stable across restarts (rotating it
# invalidates outstanding cursors, which safely degrades to "first page").
API_CURSOR_SIGNING_KEY=dev-cursor-signing-key-change-me
